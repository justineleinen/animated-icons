<!-- GSAP scripting -->
<script>
  gsap.to('#fish', {
    x: 30,
    duration: 1.5,
    repeat: -1,
    yoyo: true,
    ease: 'sine.inOut'
  });
  gsap.to('#fish', {
    y: 4,
    duration: 0.4,
    repeat: -1,
    yoyo: true,
    ease: 'sine.inOut'
  });

  const fish = document.querySelector('#fish');
  fish.addEventListener('mouseenter', () => {
    gsap.to('#fish', { scaleX: 1.2, duration: 0.3, ease: 'power2.out' });
  });
  fish.addEventListener('mouseleave', () => {
    gsap.to('#fish', { scaleX: 1, duration: 0.3, ease: 'power2.in' });
  });
</script>
