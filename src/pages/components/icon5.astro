<!-- bubble -->

<svg id="bubble" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M7.001 15.085A1.5 1.5 0 0 1 9 16.5"/>
  <circle cx="18.5" cy="8.5" r="3.5"/>
  <circle cx="7.5" cy="16.5" r="5.5"/>
  <circle cx="7.5" cy="4.5" r="2.5"/>

</svg>

<!-- GSAP Scripting -->
// Bubble — float up and fade, then reset
<script>
  gsap.fromTo('#bubble',
    { y: 0, opacity: 1 },
    {
      y: -20,
      opacity: 0,
      duration: 2,
      repeat: -1,
      ease: 'power1.in',
      repeatDelay: 0.5
    }
  );

  const bubble = document.querySelector('#bubble');
  bubble.addEventListener('mouseenter', () => {
    gsap.to('#bubble', { scale: 1.3, duration: 0.3, ease: 'power2.out' });
  });
  bubble.addEventListener('mouseleave', () => {
    gsap.to('#bubble', { scale: 1, duration: 0.3, ease: 'power2.in' });
  });
</script>
